#Random challenge5
#generate an integer between 1 and 12
#generate another integer between 1 and 12
#Multiply them together
#Ask the user to multiply them together
#Check if the user got the right answer
#Repeat the above 5 times in total
#Finally, display how many the user...
#...got correct
#But, its got errors
#Can you fix it?

import random

correctAnswerCount = 0

for i in range(5):
  num1 = random.randint(1,12)
  num2 = random.randint(1,12)
  total = num1 * num2
  num1 = str(num1)
  num2 = str(num2)
  answer = int(input("What is " + num1 + " x " + num2 + ">>>"))
  if total == answer:
    print("correct!")
    correctAnswerCount = correctAnswerCount + 1
  else:
    print("incorrect!")
print("You got",correctAnswerCount,"/5")
